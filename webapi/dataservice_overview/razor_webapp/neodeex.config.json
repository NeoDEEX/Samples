{
  "$schema": "https://neodeex.github.io/doc/neodeex.config.schema.json",
  "database": {
    "connectionStrings": {
      "DefaultConnection": {
        "type": "NeoDEEX.Data.NpgsqlClient.FoxNpgsqlDbAccess",
        "connectionString": "connectionStrings:PostgreSQL",
        "userSecrets": true
      }
    }
  },
  "webapiServer": {
    "useTypeInfo": false,
    "returnServerInfo": true,
  },
  "dataService": {
    "diagnostics": {
      "enable": true,
      "loggerName": "DataService"
    }
  },
  "logging": {
    "filter": "Verbose",
    "loggers": {
      "DataService": {
        "providerType": "NeoDEEX.Diagnostics.Loggers.FoxConsoleLoggerProvider"
      },
      "MyLogger": {
        "providerType": "NeoDEEX.Diagnostics.Loggers.FoxDebugLoggerProvider"
      }
    }
  }
}
