@page
@using System.Data
@using NeoDEEX.ServiceModel.Data
@using NeoDEEX.ServiceModel.Services;
@using NeoDEEX.ServiceModel.Services.Data
@model IndexModel
@{
    ViewData["Title"] = "Client Side Rendering";
}

<div>
  <h1 class="fs-3">Invoking Fox Data Service From Client</h1>
  <p>
    JavaScript 와 같은 클라이언트에서 원격으로 Fox Data Service 를 사용하는 예제 화면 입니다.
  </p>
  <p>
    서버 측에서 Fox Data Service 가 구성되어 있다면 FoxDataRequest 에 대응되는 JSON 객체를 POST 함으로써 Fox Data Service 를 호출할 수 있습니다.
  </p>
  <button id="query_button" class="btn btn-primary query-btn" type="submit">
    Query
  </button>
  <div class="card">
    <div class="card-header">
      Query Results
    </div>
    <div class="card-body">
      <div class="table-responsive table-container">
        <table class="table table-striped table-hover table-sm table-fixed-layout">
          <thead>
            <tr>
              <th>Order ID</th>
              <th>Customer ID</th>
              <th>Order Date</th>
              <th>Product ID</th>
              <th class="text-end">Quantity</th>
              <th class="text-end">Unit Price</th>
            </tr>
          </thead>
          <tbody id="tbody">
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<script>
const fetchOrders = async () => {
    const dataRequest = {
        queryId: "orders.get_order_by_id_with_details",
        parameters: {
            order_id: 1
        }
    }
    const httpResponse = await fetch("/api/dataservice/executedataset", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify(dataRequest)
    });
    const dataResponse = await httpResponse.json();
    const ordersTable = dataResponse.dataSet.Table;
    const card_header = document.querySelector('div.card-header');
    const tbody = document.getElementById('tbody');
    card_header.innerHTML = "Query Results";
    tbody.innerHTML = '';
    const rowCount = ordersTable.length;
    if (rowCount <= 0) {
        return;
    }
    card_header.innerHTML = card_header.innerHTML + `<span class="badge bg-success ms-2">`
        + rowCount + ' rows</span>';
    ordersTable.forEach(row => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td>${row.order_id}</td>
            <td>${row.customer_id}</td>
            <td>${row.order_date}</td>
            <td>${row.product_id}</td>
            <td class="text-end">${row.quantity}</td>
            <td class="text-end">${row.unit_price}</td>
        `;
        tbody.appendChild(tr);
    });
};

document.getElementById('query_button').addEventListener('click', fetchOrders);
</script>
