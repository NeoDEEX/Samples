{
  "$schema": "https://neodeex.github.io/doc/neodeex.config.schema.json",
  "database": {
    "connectionStrings": {
      "DefaultConnection": {
        "type": "NeoDEEX.Data.SqlClient.FoxSqlDbAccess",
        "connectionString": "Data Source=(LocalDB)\\MSSQLLocalDB;Database=TestDB;Integrated Security=True"
      }
    }
  },
  "webapiServer": {
    "useTypeInfo": true,
    "returnServerInfo": true
  },
  "dataService": {
    "diagnostics": {
      "enable": true,
      "loggerName": "DataService"
    }
  },
  "logging": {
    "filter": "Verbose",
    "loggers": {
      "DataService": {
        "providerType": "NeoDEEX.Diagnostics.Loggers.FoxConsoleLoggerProvider"
      }
    }
  }
}
