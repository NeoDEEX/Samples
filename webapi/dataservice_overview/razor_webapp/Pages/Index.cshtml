@page
@using System.Data
@using NeoDEEX.ServiceModel.Data
@using NeoDEEX.ServiceModel.Services;
@using NeoDEEX.ServiceModel.Services.Data
@model IndexModel
@{
    ViewData["Title"] = "Home page";

    FoxDataService dataService = new()
    {
        EnablePerfLog = true,
        PerfLoggerName = "DataService"
    };

    FoxDataRequest dataRequest = new("orders.get_all_orders_with_details")
    {
        Diagnostics = FoxDataRequestDiagnostics.PerformanceLog | FoxDataRequestDiagnostics.DbProfileInfo
    };
    FoxDataResponse dataResponse = dataService.ExecuteDataSet(dataRequest);
    DataTable ordersTable = dataResponse.DataSet.Tables[0];
    int rowCount = ordersTable.Rows.Count;
}
<div>
  <h1 class="fs-3">Welcome to Fox Data Service Overview</h1>
  <p>ASP.NET Core Razor Page 와 같은 SSR(Server Side Rendering) 환경에서 Fox Data Service 를 사용하는 예제 화면 입니다.</p>
  <p>
    이 페이지 예제처럼 직접 Fox Data Service 를 호출하는 코드의 장점은 크지 않습니다. 직접 FoxDbAccess 클래스를 사용하여
    Fox Query 를 호출하는 것에 비해 큰 장점이 없기 때문입니다.
  </p>
  <div class="card">
    <div class="card-header">
      Query Results
      @if (rowCount > 0)
      {
        <span class="badge bg-success ms-2">@ordersTable.Rows.Count rows</span>
      }
      <span class="badge bg-info ms-2">@dataResponse.ElapsedMilliseconds msec elapsed</span>
    </div>
    <div class="card-body">
      <div class="table-responsive table-container">
        <table class="table table-striped table-hover table-sm table-fixed-layout">
          <thead>
            <tr>
              <th>Order ID</th>
              <th>Customer ID</th>
              <th>Order Date</th>
              <th>Product ID</th>
              <th class="text-end">Quantity</th>
              <th class="text-end">Unit Price</th>
            </tr>
          </thead>
          <tbody>
            @foreach (DataRow row in ordersTable.Rows)
            {
              <tr>
                <td>@row["order_id"]</td>
                <td>@row["customer_id"]</td>
                <td>@row["order_date"]</td>
                <td>@row["product_id"]</td>
                <td class="text-end">@row["quantity"]</td>
                <td class="text-end">@row["unit_price"]</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<div class="card">
  <div class="card-header">
    Performance Log
  </div>
  <div class="card-body">
    <pre><code class="plaintext">@dataResponse.PerformanceInfo.ToString()</code></pre>
  </div>
</div>
<div class="card">
  <div class="card-header" id="headingTwo">
    DB Profile Info
  </div>
  <div class="card-body">
    <pre><code class="plaintext">@dataResponse.DbProfileInfo.ToString()</code></pre>
  </div>
</div>
<hr />
@{
    //
    // 다중 쿼리 예제 입니다.
    //
    // 주) 이 예제의 쿼리는 굳이 다중 쿼리를 사용할 필요 없이 단일 쿼리로도 구현이 가능하며
    //     오히려 단일 쿼리로 구현해야 성능이나 효율에 좋습니다. 다중 쿼리의 예를 보이기 위한
    //     예제임을 감안해 주십시요.
    FoxDataRequestCollection requests = new(String.Empty)
    {
        new FoxDataRequest("orders.get_order_by_id") { Operation = FoxDataOperations.ExecuteDataSet },
        new FoxDataRequest("orders.get_details_by_id") { Operation = FoxDataOperations.ExecuteDataSet, Transaction = FoxDataTransactions.Local },
    };
    requests[0].Parameters["order_id"] = 1;
    requests[1].Parameters["order_id"] = 1;
    FoxDataResponseCollection responses = dataService.ExecuteMultiple(requests);
    DataRow orderRow = responses[0].DataSet.Tables[0].Rows[0];
    DataTable detailsTable = responses[1].DataSet.Tables[0];
}
<div class="card">
  <div class="card-header">
    Order Information
    <span class="badge bg-info ms-2">@responses.ElapsedMilliseconds msec elapsed</span>
  </div>
  <div class="card-body">
    <div class="container">
      <div class="row">
        <div class="col">
          <p class="card-title">Order ID: @orderRow["order_id"]</p>
          <p class="card-text">Customer ID: @orderRow["customer_id"]</p>
          <p class="card-text">Employee ID: @orderRow["employee_id"]</p>
          <p class="card-text">Order Date: @orderRow["order_date"]</p>
          <p class="card-text">Ship Date: @orderRow["shipped_date"]</p>
          <p class="card-text">Ship Address: @orderRow["ship_address"]</p>
        </div>
        <div class="col">
          @foreach (DataRow row in detailsTable.Rows)
          {
            <div class="card">
              <div class="card-header">
                Order Detail - Product ID: @row["product_id"]
              </div>
              <div class="card-body">
                Quantity: @row["quantity"]<br/>
                Unit Price: @row["unit_price"]
              </div>
            </div>
          }
        </div>
      </div>
    </div>
  </div>
</div>
