<?xml version="1.0" encoding="utf-8" ?>
<queryMap xmlns="http://schema.neodeex.net/fx/foxml/2023/04/">
  <statements>
    <statement id="GetProducts">
      <text>
        SELECT Id, ProductName, SupplierId, UnitPrice, Package FROM Sample_Products
      </text>
    </statement>
    <statement id="GetRawData">
      <text>
        SELECT * FROM Sample_Products
      </text>
    </statement>
  </statements>
</queryMap>
